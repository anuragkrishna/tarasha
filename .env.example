# Firebase web config — copy to .env.local for local dev, and add the same keys
# in Vercel → Project → Settings → Environment Variables (then redeploy).
# These are NOT secrets; access is protected by Firestore security rules.
# Find them in Firebase Console → Project settings → Your apps → Web app → SDK setup & config.
# If these are absent, the app runs as guest-only (no Google login, local progress).

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
